# Environment variables for cloud deployment

# Backend production environment
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PASSWORD@CLOUD_SQL_IP:5432/rubiscape_ml
SECRET_KEY=your-very-secure-random-secret-key-here-change-this
ENVIRONMENT=production
ALLOWED_ORIGINS=https://your-frontend-domain.com,https://storage.googleapis.com/your-bucket-name

# GCP Configuration
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1
CLOUD_SQL_INSTANCE=rubiscape-db
CLOUD_SQL_USER=postgres

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false
LOG_LEVEL=info

# Security
CORS_ORIGINS_ALLOW_ALL=false
TRUST_PROXY=true
HTTPS_ONLY=true

# Database
DB_POOL_SIZE=20
DB_POOL_MAX_OVERFLOW=0
DB_ECHO=false
